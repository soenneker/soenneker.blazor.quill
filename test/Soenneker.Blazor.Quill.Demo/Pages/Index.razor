@page "/"
@using Microsoft.Extensions.Logging
@using Soenneker.Blazor.Quill.Dtos
@using Soenneker.Blazor.Quill.Options

@inject ILogger<Index> Logger

<PageTitle>Soenneker.Blazor.Quill Demo</PageTitle>

<style>
    .demo-quill .ql-container {
        min-height: 14rem;
    }

    .demo-quill-output {
        white-space: pre-wrap;
        word-break: break-word;
    }
</style>

<Div Space="Space.Y.Is6">
    <Div Space="Space.Y.Is2">
        <Div TextSize="TextSize.ThreeXl" FontWeight="FontWeight.Bold">Quill Editor</Div>
        <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
            The editor below is bound to HTML and text, and exposes Quill content and selection changes back into Blazor.
        </Paragraph>
    </Div>

    <Div Rounded="Rounded.Lg"
         Border="Border.Is1"
         BorderColor="BorderColor.Border"
         Padding="Padding.Is4"
         Space="Space.Y.Is4">
        <Div Space="Space.Y.Is1">
            <Div TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold">Editor</Div>
            <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                Type directly in the Quill editor or push content from Blazor.
            </Paragraph>
        </Div>

        <QuillEditor @ref="_editor"
                     Class="demo-quill"
                     Options="_options"
                     @bind-Html="_html"
                     @bind-Text="_text"
                     OnTextChange="OnTextChanged"
                     OnSelectionChange="OnSelectionChanged" />

        <Div Display="Display.Flex" Flex=@("flex-wrap") Gap="Gap.Is2">
            <Button OnClick="SetExampleContent">Set example content</Button>
            <Button OnClick="LoadDeltaContent" Variant="ButtonVariant.Secondary">Load delta JSON</Button>
            <Button OnClick="FocusEditor" Variant="ButtonVariant.Outline">Focus</Button>
            <Button OnClick="ClearEditor" Variant="ButtonVariant.Destructive">Clear</Button>
        </Div>

        <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
            Selection: @(_selectionSummary ?? "none")
        </Paragraph>
    </Div>

    <Grid Columns="Columns.Is1.OnLg.Is2" Gap="Gap.Is4">
        <Div Rounded="Rounded.Lg"
             Border="Border.Is1"
             BorderColor="BorderColor.Border"
             Padding="Padding.Is4"
             Space="Space.Y.Is3">
            <Div Space="Space.Y.Is1">
                <Div TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold">Plain text</Div>
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    The latest plain-text value from Quill.
                </Paragraph>
            </Div>
            <Div Rounded="Rounded.Md"
                 Border="Border.Is1"
                 BorderColor="BorderColor.Border"
                 BackgroundColor="BackgroundColor.Muted"
                 Padding="Padding.Is4"
                 Class="demo-quill-output">
                @(_text ?? string.Empty)
            </Div>
        </Div>

        <Div Rounded="Rounded.Lg"
             Border="Border.Is1"
             BorderColor="BorderColor.Border"
             Padding="Padding.Is4"
             Space="Space.Y.Is3">
            <Div Space="Space.Y.Is1">
                <Div TextSize="TextSize.Lg" FontWeight="FontWeight.Semibold">Rendered HTML</Div>
                <Paragraph Margin="Margin.Is0" TextSize="TextSize.Sm" TextColor="TextColor.MutedForeground">
                    The latest HTML generated by Quill.
                </Paragraph>
            </Div>
            <Div Rounded="Rounded.Md"
                 Border="Border.Is1"
                 BorderColor="BorderColor.Border"
                 BackgroundColor="BackgroundColor.Muted"
                 Padding="Padding.Is4"
                 Class="demo-quill-output">
                @(_html ?? string.Empty)
            </Div>
        </Div>
    </Grid>
</Div>

@code {
    private QuillEditor? _editor;
    private string? _html;
    private string? _text;
    private string? _selectionSummary;

    private readonly QuillOptions _options = new()
    {
        Placeholder = "Start typing...",
        Theme = "snow",
        Modules = new Dictionary<string, object?>
        {
            ["toolbar"] = new object[]
            {
                new[] {"bold", "italic", "underline"},
                new[] {"blockquote", "code-block"},
                new[] {"link", "image"},
                new[] {"clean"}
            }
        }
    };

    private Task OnTextChanged(QuillTextChange change)
    {
        Logger.LogInformation("Quill text changed via {Source}", change.Source);
        return Task.CompletedTask;
    }

    private Task OnSelectionChanged(QuillSelectionChange change)
    {
        _selectionSummary = change.Range == null ? "none" : $"index={change.Range.Index}, length={change.Range.Length}";
        return Task.CompletedTask;
    }

    private async Task SetExampleContent()
    {
        if (_editor == null)
            return;

        await _editor.SetHtml("<h2>Hello from Quill</h2><p>This content was pushed from <strong>Blazor</strong>.</p>");
    }

    private async Task LoadDeltaContent()
    {
        if (_editor == null)
            return;

        const string deltaJson = """
                                 {"ops":[{"insert":"Delta-driven content from Blazor\n"},{"attributes":{"bold":true},"insert":"Bold line"},{"insert":"\n"}]}
                                 """;

        await _editor.SetContents(deltaJson);
    }

    private async Task FocusEditor()
    {
        if (_editor != null)
            await _editor.Focus();
    }

    private async Task ClearEditor()
    {
        if (_editor != null)
            await _editor.Clear();
    }
}
